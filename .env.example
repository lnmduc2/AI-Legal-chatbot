# OpenAI-compatible API configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://litellm.inter-k.com
AI_LEGAL_MODEL=openai/kCode

LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Legal automation demo
LEGAL_AUTOMATION_ENABLED=true
LEGAL_SOURCE_LABEL=thuvienphapluat.vn

# Gmail source account used by the fake legal-source app
LEGAL_MAIL_SOURCE_EMAIL=
LEGAL_MAIL_SOURCE_APP_PASSWORD=

# Gmail admin inbox read by the main app poller
LEGAL_MAIL_ADMIN_EMAIL=
LEGAL_MAIL_ADMIN_APP_PASSWORD=

# Legal team recipients notified after successful ingestion
LEGAL_MAIL_TEAM_RECIPIENTS=

# Mail transport
LEGAL_MAIL_SMTP_HOST=smtp.gmail.com
LEGAL_MAIL_SMTP_PORT=587
LEGAL_MAIL_IMAP_HOST=imap.gmail.com
LEGAL_MAIL_IMAP_PORT=993
LEGAL_MAIL_POLL_INTERVAL_SECONDS=15
LEGAL_MAIL_MAX_MESSAGES_PER_POLL=20

# Heuristic keywords
LEGAL_MAIL_SUBJECT_KEYWORDS=cập nhật pháp luật,văn bản pháp luật,luật,bảo vệ dữ liệu,dữ liệu cá nhân,quy định mới,nghị định,thông tư
LEGAL_MAIL_BODY_KEYWORDS=bảo vệ dữ liệu,dữ liệu cá nhân,quy định mới,cập nhật pháp luật,nghĩa vụ tuân thủ,quyền của chủ thể dữ liệu,xử lý dữ liệu cá nhân
LEGAL_MAIL_ATTACHMENT_SUFFIXES=.md